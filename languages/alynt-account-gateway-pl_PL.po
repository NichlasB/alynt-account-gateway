#: includes/services/class-privacy-service.php:79
#: includes/services/class-privacy-service.php:94
msgid "Alynt Account Gateway"
msgstr "Alynt Account Gateway"

#: includes/class-activator.php:42
msgid "Alynt Account Gateway could not create or update its database tables. Check the database permissions and try again."
msgstr "Alynt Account Gateway nie mógł utworzyć ani zaktualizować swoich tabel bazy danych. Sprawdź uprawnienia bazy danych i spróbuj ponownie."

#: includes/services/class-privacy-exporter.php:127
msgid "Alynt Account Gateway could not retrieve all personal data. Please retry the export and check the site database if the problem continues."
msgstr "Alynt Account Gateway nie mógł pobrać wszystkich danych osobowych. Ponów eksport i sprawdź bazę danych witryny, jeśli problem się powtarza."

#: includes/services/class-privacy-service.php:66
msgid "Alynt Account Gateway may process account registration data, email verification results, webhook delivery metadata, and consent records. Site owners should disclose configured third-party services such as Cloudflare Turnstile, Reoon Email Verifier, and outgoing webhooks."
msgstr "Alynt Account Gateway może przetwarzać dane rejestracji konta, wyniki weryfikacji adresów e-mail, metadane dostarczania webhooków oraz zapisy zgód. Właściciele witryny powinni ujawnić skonfigurowane usługi zewnętrzne, takie jak Cloudflare Turnstile, Reoon Email Verifier oraz wychodzące webhooki."

#: includes/class-activator.php:26
msgid "Alynt Account Gateway must be activated separately on each site in a multisite network."
msgstr "Alynt Account Gateway musi zostać aktywowany osobno w każdej witrynie sieci multisite."

#: includes/services/class-compatibility-warnings.php:78
msgid "Alynt Account Gateway will require login before the main checkout, but WooCommerce still permits guest checkout. Review both settings and test every checkout entry point before launch."
msgstr "Alynt Account Gateway będzie wymagać logowania przed głównym zamówieniem, ale WooCommerce nadal zezwala na zakupy bez rejestracji. Sprawdź oba ustawienia i przetestuj każde wejście do zamówienia przed uruchomieniem."

#: admin/settings-page/class-readiness-summary.php:98
