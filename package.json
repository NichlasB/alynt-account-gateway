{
  "name": "alynt-account-gateway",
  "version": "0.1.24",
  "private": true,
  "description": "Alynt Account Gateway build tooling.",
  "type": "module",
  "scripts": {
    "build": "node scripts/build.mjs",
    "dev": "node scripts/build.mjs --watch",
    "lint": "php ./vendor/bin/phpcs --standard=.phpcs.xml .",
    "lint:fix": "php ./vendor/bin/phpcbf --standard=.phpcs.xml .",
    "make-pot": "node scripts/make-pot.mjs",
    "test": "php ./vendor/bin/phpunit -c phpunit.xml.dist"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "esbuild": "^0.28.1",
    "nodemon": "^3.1.0"
  }
}
